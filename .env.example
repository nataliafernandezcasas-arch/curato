NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
RESEND_API_KEY=your_resend_api_key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Phyllo (Instagram follower verification)
PHYLLO_CLIENT_ID=your_phyllo_client_id
PHYLLO_CLIENT_SECRET=your_phyllo_client_secret
PHYLLO_API_URL=https://api.staging.getphyllo.com
NEXT_PUBLIC_PHYLLO_ENV=staging

# PassKit.com (Apple Wallet + Google Wallet for Midi Pass)
# Get these from PassKit dashboard: Account -> Service Accounts -> create JWT
PASSKIT_API_KEY=
PASSKIT_PROGRAM_ID=
PASSKIT_TIER_ID=
PASSKIT_API_URL=https://api.pub2.passkit.io

# Shared secret between midi-pass and midi-crm. Generate with: uuidgen
INTERNAL_API_KEY=

# Shared password to access /admin/*. Anyone with this clave puede entrar.
# Cookie dura 30 días. Cambiar el valor invalida todas las sesiones.
ADMIN_PASS=
